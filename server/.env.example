# Anthropic API Key
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Voyage AI API Key (for RAG embeddings)
# Get your key from: https://dash.voyageai.com/
VOYAGE_API_KEY=your-voyage-key-here

# Admin API Key (for admin endpoints)
# Generate a secure random string
ADMIN_API_KEY=your-admin-key-here

# Alert Webhook URL (for error notifications + live-takeover handoff pings)
# Discord: https://discord.com/api/webhooks/...
# Slack: https://hooks.slack.com/services/...
ALERT_WEBHOOK_URL=

# Public base URL of the deployed app (e.g. the Railway URL). Used to build the
# deep link into the live-takeover console (/live.html) that ships in Discord
# handoff alerts. Leave unset in dev; the link is simply omitted.
PUBLIC_URL=

# Database Path (optional, defaults to ./data/chat.db)
DATABASE_PATH=./data/chat.db

# Server Port (optional, defaults to 3000)
PORT=3000

# SendGrid (email follow-ups)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=milos@thesnowmedia.com

# Environment
NODE_ENV=development
